<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:BillWise.Views"
       x:Class="BillWise.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.TabBarBackgroundColor="White"
       Shell.TabBarForegroundColor="#185FA5"
       Shell.TabBarUnselectedColor="#9E9E9E"
       Shell.TabBarTitleColor="#185FA5"
       Shell.NavBarIsVisible="False">

    <TabBar>
        <ShellContent Title="Home"
                      Icon="tab_home.png"
                      Route="HomePage"
                      ContentTemplate="{DataTemplate views:HomePage}"/>
        <ShellContent Title="Invoices"
                      Icon="tab_invoices.png"
                      Route="InvoicesPage"
                      ContentTemplate="{DataTemplate views:InvoicesPage}"/>
        <ShellContent Title="Stats"
                      Icon="tab_stats.png"
                      Route="StatisticsPage"
                      ContentTemplate="{DataTemplate views:StatisticsPage}"/>
        <ShellContent Title="Alerts"
                      Icon="tab_alerts.png"
                      Route="AlertsPage"
                      ContentTemplate="{DataTemplate views:AlertsPage}"/>
        <ShellContent Title="Profile"
                      Icon="tab_profile.png"
                      Route="ProfilePage"
                      ContentTemplate="{DataTemplate views:ProfilePage}"/>
    </TabBar>

</Shell>