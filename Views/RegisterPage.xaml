<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             BackgroundColor="#3498DB"
             NavigationPage.HasNavigationBar="False"
             Shell.TabBarIsVisible="False">

    <ScrollView>
        <Grid RowDefinitions="240,*" MinimumHeightRequest="700">

            <!-- Blue Header -->
            <VerticalStackLayout Grid.Row="0"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Spacing="8">
                <Image Source="logo.png"
                       WidthRequest="280" HeightRequest="100"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"/>
                <Label Text="{Binding [JoinToday], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="14"
                    TextColor="#D6EAF8" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- White form -->
            <Border Grid.Row="1" BackgroundColor="White"
                    StrokeThickness="0" Padding="28,36,28,40">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="36,36,0,0"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <Label Text="{Binding [CreateAccount], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="26"
                           FontAttributes="Bold" TextColor="#1A1A2E"
                           Margin="0,0,0,6"/>
                    <Label Text="{Binding [JoinToday], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           FontSize="14" TextColor="#9CA3AF"
                           Margin="0,0,0,24"/>

                    <!-- Email -->
                    <Label Text="{Binding [EmailAddress], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13"
                           FontAttributes="Bold" TextColor="#374151"
                           Margin="0,0,0,6"/>
                    <Border Stroke="#E5E7EB" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#F9FAFB"
                            Padding="16,0" HeightRequest="56"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding Email}"
                               Placeholder="name@example.com"
                               Keyboard="Email"
                               BackgroundColor="Transparent"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <!-- Password -->
                    <Label Text="{Binding [Password], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13"
                           FontAttributes="Bold" TextColor="#374151"
                           Margin="0,0,0,6"/>
                    <Border Stroke="#E5E7EB" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#F9FAFB"
                            Padding="16,0" HeightRequest="56"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding Password}"
                               Placeholder="At least 6 characters"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <!-- Confirm Password -->
                    <Label Text="{Binding [ConfirmPassword], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13"
                           FontAttributes="Bold" TextColor="#374151"
                           Margin="0,0,0,6"/>
                    <Border Stroke="#E5E7EB" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#F9FAFB"
                            Padding="16,0" HeightRequest="56"
                            Margin="0,0,0,28">
                        <Entry Text="{Binding ConfirmPassword}"
                               Placeholder="Repeat your password"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <Button Text="{Binding [CreateAccount], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="#3498DB" TextColor="White"
                            CornerRadius="14" HeightRequest="56"
                            FontAttributes="Bold" FontSize="16"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#3498DB"
                                       HorizontalOptions="Center"
                                       Margin="0,12,0,0"/>

                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="4" Margin="0,24,0,0">
                        <Label Text="{Binding [AlreadyHaveAccount], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               TextColor="#9CA3AF" FontSize="14"
                               VerticalOptions="Center"/>
                        <Label Text="{Binding [SignIn], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="#3498DB"
                               FontAttributes="Bold" FontSize="14"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding GoBackCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>