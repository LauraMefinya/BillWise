<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             x:Class="BillWise.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             BackgroundColor="#3498DB"
             NavigationPage.HasNavigationBar="False"
             Shell.TabBarIsVisible="False">

    <ScrollView>
        <Grid RowDefinitions="240,*" MinimumHeightRequest="700">

            <!-- Blue Header -->
            <VerticalStackLayout Grid.Row="0"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Spacing="8">
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        WidthRequest="70" HeightRequest="70"
                        StrokeShape="RoundRectangle 18"
                        HorizontalOptions="Center">
                    <Label Text="BW" FontSize="24"
                        FontAttributes="Bold"
                        TextColor="#3498DB"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>
                <Label Text="Create Account" FontSize="28"
                    FontAttributes="Bold" TextColor="White"
                    HorizontalOptions="Center"/>
                <Label Text="Join BillWise today" FontSize="14"
                    TextColor="#D6EAF8" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- White form -->
            <Border Grid.Row="1" BackgroundColor="White"
                    StrokeThickness="0" Padding="28,36,28,40">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="36,36,0,0"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <!-- Email -->
                    <Label Text="Email Address" FontSize="13"
                           FontAttributes="Bold" TextColor="#374151"
                           Margin="0,0,0,6"/>
                    <Border Stroke="#E5E7EB" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#F9FAFB"
                            Padding="16,0" HeightRequest="56"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding Email}"
                               Placeholder="name@example.com"
                               Keyboard="Email"
                               BackgroundColor="Transparent"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <!-- Password -->
                    <Label Text="Password" FontSize="13"
                           FontAttributes="Bold" TextColor="#374151"
                           Margin="0,0,0,6"/>
                    <Border Stroke="#E5E7EB" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#F9FAFB"
                            Padding="16,0" HeightRequest="56"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding Password}"
                               Placeholder="At least 6 characters"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <!-- Confirm Password -->
                    <Label Text="Confirm Password" FontSize="13"
                           FontAttributes="Bold" TextColor="#374151"
                           Margin="0,0,0,6"/>
                    <Border Stroke="#E5E7EB" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#F9FAFB"
                            Padding="16,0" HeightRequest="56"
                            Margin="0,0,0,28">
                        <Entry Text="{Binding ConfirmPassword}"
                               Placeholder="Repeat your password"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <Button Text="Create Account"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="#3498DB" TextColor="White"
                            CornerRadius="14" HeightRequest="56"
                            FontAttributes="Bold" FontSize="16"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#3498DB"
                                       HorizontalOptions="Center"
                                       Margin="0,12,0,0"/>

                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="4" Margin="0,24,0,0">
                        <Label Text="Already have an account?"
                               TextColor="#9CA3AF" FontSize="14"
                               VerticalOptions="Center"/>
                        <Label Text="Sign In" TextColor="#3498DB"
                               FontAttributes="Bold" FontSize="14"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding GoBackCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>