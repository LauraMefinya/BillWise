<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False"
             x:Class="BillWise.Views.AccountSettingsPage"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="16,0,16,40">

            <!-- Header -->
            <VerticalStackLayout Spacing="4" Padding="0,1,0,0">
                <Button Text="‹ Back"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="#3498DB"
                        FontSize="16"
                        HorizontalOptions="Start"
                        Padding="0"
                        Margin="-4,0,0,0"/>
                <Label Text="{Binding [AccountSettings], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                       FontSize="26" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>
            </VerticalStackLayout>

            <!-- Settings Card -->
            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14">
                <VerticalStackLayout>

                    <!-- Language -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12">
                        <Border Grid.Column="0" BackgroundColor="#DBEAFE"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                WidthRequest="40" HeightRequest="40"
                                VerticalOptions="Center">
                            <Label Text="🌐" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="{Binding [Language], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                               FontSize="15" VerticalOptions="Center"
                               Margin="14,0,0,0"/>
                        <Picker Grid.Column="2"
                                ItemsSource="{Binding LanguageOptions}"
                                SelectedItem="{Binding SelectedLanguage}"
                                TextColor="{AppThemeBinding Light=#3498DB, Dark=#60A5FA}"
                                FontAttributes="Bold"
                                FontSize="15"
                                VerticalOptions="Center"
                                WidthRequest="80"/>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D3D}"
                             Margin="16,0"/>

                    <!-- Haptic Feedback -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,6">
                        <Border Grid.Column="0" BackgroundColor="#F3E8FF"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                WidthRequest="40" HeightRequest="40"
                                VerticalOptions="Center">
                            <Label Text="📳" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="{Binding [HapticFeedback], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                               FontSize="15" VerticalOptions="Center"
                               Margin="14,0,0,0"/>
                        <Switch Grid.Column="2"
                                IsToggled="{Binding HapticFeedbackEnabled}"
                                OnColor="#3498DB"
                                VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D3D}"
                             Margin="16,0"/>

                    <!-- Export Data -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,16">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ExportDataCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0" BackgroundColor="#D1FAE5"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                WidthRequest="40" HeightRequest="40"
                                VerticalOptions="Center">
                            <Label Text="📤" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="{Binding [ExportData], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                               FontSize="15" VerticalOptions="Center"
                               Margin="14,0,0,0"/>
                        <Label Grid.Column="2" Text="›"
                               FontSize="24" TextColor="#9CA3AF"
                               VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D3D}"
                             Margin="16,0"/>

                    <!-- Clear Data -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,16">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearAllDataCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0" BackgroundColor="#FEE2E2"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                WidthRequest="40" HeightRequest="40"
                                VerticalOptions="Center">
                            <Label Text="🗑️" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="{Binding [ClearAllData], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               TextColor="#EF4444"
                               FontSize="15" VerticalOptions="Center"
                               Margin="14,0,0,0"/>
                        <Label Grid.Column="2" Text="›"
                               FontSize="24" TextColor="#9CA3AF"
                               VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D3D}"
                             Margin="16,0"/>

                    <!-- Logout -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,16">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0" BackgroundColor="#FEE2E2"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                WidthRequest="40" HeightRequest="40"
                                VerticalOptions="Center">
                            <Label Text="🚪" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="{Binding [Logout], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               TextColor="#EF4444"
                               FontSize="15" VerticalOptions="Center"
                               Margin="14,0,0,0"/>
                        <Label Grid.Column="2" Text="›"
                               FontSize="24" TextColor="#9CA3AF"
                               VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D3D}"
                             Margin="16,0"/>

                    <!-- Delete Account -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,16">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DeleteAccountCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0" BackgroundColor="#FEE2E2"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                WidthRequest="40" HeightRequest="40"
                                VerticalOptions="Center">
                            <Label Text="⚠️" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="{Binding [DeleteAccount], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               TextColor="#EF4444"
                               FontAttributes="Bold"
                               FontSize="15" VerticalOptions="Center"
                               Margin="14,0,0,0"/>
                        <Label Grid.Column="2" Text="›"
                               FontSize="24" TextColor="#9CA3AF"
                               VerticalOptions="Center"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#3498DB"
                               HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
