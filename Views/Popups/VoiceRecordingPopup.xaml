<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:strings="clr-namespace:BillWise.Resources.Strings"
               x:Class="BillWise.Views.Popups.VoiceRecordingPopup"
               x:TypeArguments="x:String">

    <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
            StrokeShape="RoundRectangle 20"
            StrokeThickness="0"
            WidthRequest="340"
            Padding="20,24">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.12"/>
        </Border.Shadow>

        <VerticalStackLayout Spacing="20">

            <!-- Header: mic circle + title/subtitle -->
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16" VerticalOptions="Center">

                <!-- Mic icon with pulse ring -->
                <Grid Grid.Column="0" WidthRequest="56" HeightRequest="56">
                    <Ellipse x:Name="PulseRing"
                             Fill="Transparent"
                             Stroke="#3498DB"
                             StrokeThickness="2"
                             Opacity="0"
                             WidthRequest="56" HeightRequest="56"
                             HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border BackgroundColor="#EBF5FB"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 28"
                            WidthRequest="48" HeightRequest="48"
                            HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="🎤" FontSize="22"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Title + subtitle -->
                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Label Text="{Binding [VoiceListening], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>
                    <Label x:Name="StatusLabel"
                           Text="{Binding [VoicePlaceholder], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Waveform bars -->
            <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,*,*,*,*,*,*,*"
                  ColumnSpacing="4" HeightRequest="40"
                  HorizontalOptions="Fill">
                <BoxView x:Name="Bar1"  Grid.Column="0"  BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="10" VerticalOptions="Center"/>
                <BoxView x:Name="Bar2"  Grid.Column="1"  BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="20" VerticalOptions="Center"/>
                <BoxView x:Name="Bar3"  Grid.Column="2"  BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="30" VerticalOptions="Center"/>
                <BoxView x:Name="Bar4"  Grid.Column="3"  BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="16" VerticalOptions="Center"/>
                <BoxView x:Name="Bar5"  Grid.Column="4"  BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="36" VerticalOptions="Center"/>
                <BoxView x:Name="Bar6"  Grid.Column="5"  BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="22" VerticalOptions="Center"/>
                <BoxView x:Name="Bar7"  Grid.Column="6"  BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="40" VerticalOptions="Center"/>
                <BoxView x:Name="Bar8"  Grid.Column="7"  BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="18" VerticalOptions="Center"/>
                <BoxView x:Name="Bar9"  Grid.Column="8"  BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="32" VerticalOptions="Center"/>
                <BoxView x:Name="Bar10" Grid.Column="9"  BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="14" VerticalOptions="Center"/>
                <BoxView x:Name="Bar11" Grid.Column="10" BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="26" VerticalOptions="Center"/>
                <BoxView x:Name="Bar12" Grid.Column="11" BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="10" VerticalOptions="Center"/>
                <BoxView x:Name="Bar13" Grid.Column="12" BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="20" VerticalOptions="Center"/>
                <BoxView x:Name="Bar14" Grid.Column="13" BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="34" VerticalOptions="Center"/>
                <BoxView x:Name="Bar15" Grid.Column="14" BackgroundColor="#3498DB" CornerRadius="3" HeightRequest="12" VerticalOptions="Center"/>
            </Grid>

            <!-- Live transcription -->
            <Border BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#252836}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="14,10"
                    MinimumHeightRequest="56">
                <Label x:Name="TranscriptionLabel"
                       Text="{Binding [VoicePlaceholder], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                       FontSize="14"
                       TextColor="#9CA3AF"
                       LineBreakMode="WordWrap"/>
            </Border>

            <!-- Cancel / Validate buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="{Binding [Cancel], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                        BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#374151}"
                        TextColor="{AppThemeBinding Light=#6B7280, Dark=#D1D5DB}"
                        CornerRadius="12"
                        HeightRequest="48"
                        FontAttributes="Bold"
                        Clicked="OnCancelClicked"/>
                <Button x:Name="ValidateButton"
                        Grid.Column="1"
                        Text="{Binding [Validate], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                        BackgroundColor="#3498DB"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="48"
                        FontAttributes="Bold"
                        IsEnabled="False"
                        Clicked="OnValidateClicked"/>
            </Grid>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
