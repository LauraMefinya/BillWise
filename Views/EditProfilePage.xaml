<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.EditProfilePage"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <!-- Header section (Blue Background) -->
            <Grid BackgroundColor="#3498DB" Padding="20,40,20,40">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Border StrokeShape="RoundRectangle 40" WidthRequest="80" HeightRequest="80" BackgroundColor="#2980B9" StrokeThickness="0" HorizontalOptions="Center">
                        <Label Text="👤" FontSize="36" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border StrokeShape="RoundRectangle 8" BackgroundColor="#5DADE2" StrokeThickness="0" Padding="12,8">
                        <Entry Text="{Binding UserName}" TextColor="White" PlaceholderColor="#EBF5FB" FontSize="18" FontAttributes="Bold" BackgroundColor="Transparent" HorizontalTextAlignment="Center"/>
                    </Border>
                    <Border StrokeShape="RoundRectangle 8" BackgroundColor="#5DADE2" StrokeThickness="0" Padding="12,8" Margin="0,-10,0,0">
                        <Entry Text="{Binding UserEmail}" TextColor="White" PlaceholderColor="#EBF5FB" FontSize="14" Keyboard="Email" BackgroundColor="Transparent" HorizontalTextAlignment="Center"/>
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Spacing="24" Padding="16,24,16,60" Margin="0,-20,0,0">

                <!-- Summary Card -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="20">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="16" RowSpacing="24">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="{Binding TotalInvoices}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" HorizontalOptions="Center"/>
                            <Label Text="{Binding [TotalInvoices], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="{Binding PaidInvoices}" FontSize="24" FontAttributes="Bold" TextColor="#10B981" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Paid], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="{Binding PendingInvoices}" FontSize="24" FontAttributes="Bold" TextColor="#F59E0B" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Pending], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="{Binding OverdueInvoices}" FontSize="24" FontAttributes="Bold" TextColor="#EF4444" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Overdue], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Label Text="{Binding [Settings], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>

                <!-- Currency & Language -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,12,Auto">
                        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#D1FAE5" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="💲" FontSize="16"/>
                        </Border>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding [Currency], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="14" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Picker Grid.Row="0" Grid.Column="2" SelectedItem="{Binding SelectedCurrency}" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" BackgroundColor="Transparent" WidthRequest="70">
                            <Picker.Items>
                                <x:String>£</x:String>
                                <x:String>€</x:String>
                                <x:String>$</x:String>
                            </Picker.Items>
                        </Picker>

                        <Border Grid.Row="2" Grid.Column="0" BackgroundColor="#DBEAFE" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="🌐" FontSize="16"/>
                        </Border>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding [Language], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="14" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Picker Grid.Row="2" Grid.Column="2" SelectedItem="{Binding SelectedLanguage}" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" BackgroundColor="Transparent" WidthRequest="80">
                            <Picker.Items>
                                <x:String>en</x:String>
                                <x:String>fr</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>
                </Border>

                <!-- Notifications -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" BackgroundColor="#FFEDD5" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Start">
                            <Label Text="🔔" FontSize="16"/>
                        </Border>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding [Notifications], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="12" Margin="12,0,0,0"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding [Enabled], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" FontSize="14" Margin="12,0,0,0"/>
                        <Switch Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" IsToggled="{Binding NotificationsEnabled}" VerticalOptions="Center"/>

                        <Label Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding [ReminderDays], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="12" Margin="12,16,0,4"/>
                        <Border Grid.Row="3" Grid.Column="1" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 4" BackgroundColor="{AppThemeBinding Light=White, Dark=#252836}" Margin="12,0,0,0" Padding="8,0" HorizontalOptions="Start" WidthRequest="60">
                            <Entry Text="{Binding ReminderDays, FallbackValue='2'}" Keyboard="Numeric" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" HorizontalTextAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Haptic Feedback -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" BackgroundColor="#F3E8FF" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Start">
                            <Label Text="📳" FontSize="16"/>
                        </Border>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding [HapticFeedback], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="12" Margin="12,0,0,0"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding [Enabled], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" FontSize="14" Margin="12,0,0,0"/>
                        <Switch Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" IsToggled="{Binding HapticFeedbackEnabled}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Dark Mode -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" BackgroundColor="#E0F2FE" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Start">
                            <Label Text="🌙" FontSize="16"/>
                        </Border>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding [DarkMode], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="12" Margin="12,0,0,0"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding [Enabled], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" FontSize="14" Margin="12,0,0,0"/>
                        <Switch Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" IsToggled="{Binding DarkModeEnabled}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                    <Button Grid.Column="0" Text="{Binding [Cancel], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding CancelChangesCommand}" BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" TextColor="{AppThemeBinding Light=#4B5563, Dark=#D1D5DB}" CornerRadius="8" FontAttributes="Bold"/>
                    <Button Grid.Column="1" Text="{Binding [Save], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding SaveSettingsCommand}" BackgroundColor="#3498DB" TextColor="White" CornerRadius="8" FontAttributes="Bold"/>
                </Grid>

                <Button Text="{Binding [ExportData], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding ExportDataCommand}" BackgroundColor="#10B981" TextColor="White" CornerRadius="8" FontAttributes="Bold" Margin="0,10,0,0"/>

                <Button Text="{Binding [ClearAllData], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding ClearAllDataCommand}" BackgroundColor="#EF4444" TextColor="White" CornerRadius="8" FontAttributes="Bold"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
