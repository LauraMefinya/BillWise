<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             x:Class="BillWise.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             BackgroundColor="#3498DB"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView VerticalOptions="FillAndExpand">
            <Grid RowDefinitions="Auto, Auto">

                <!-- Logo Area -->
                <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center"
                                     VerticalOptions="End" Margin="0,50,0,40">
                    <Border BackgroundColor="White" StrokeThickness="0"
                            WidthRequest="80" HeightRequest="80"
                            StrokeShape="RoundRectangle 20"
                            HorizontalOptions="Center">
                        <Label Text="💳" FontSize="40"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="BillWise" FontSize="32" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center"
                           Margin="0,16,0,0"/>
                    <Label Text="Manage your invoices smartly"
                           FontSize="14" TextColor="#E0F2FE"
                           HorizontalOptions="Center" Margin="0,4,0,0"/>
                </VerticalStackLayout>

                <!-- Login Form -->
                <Border Grid.Row="1" BackgroundColor="White"
                        StrokeThickness="0" Margin="0" Padding="30,40,30,50">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40,40,0,0"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="20">
                        <Label Text="Welcome Back" FontSize="24"
                               FontAttributes="Bold" TextColor="#001F3F"
                               HorizontalOptions="Start"/>
                        <Label Text="Sign in to continue" FontSize="14"
                               TextColor="#6B7280" HorizontalOptions="Start"
                               Margin="0,-16,0,10"/>

                        <!-- Email Input -->
                        <Border Stroke="#E5E7EB" StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#F9FAFB"
                                Padding="16,4" HeightRequest="60">
                            <HorizontalStackLayout Spacing="16">
                                <Label Text="✉️" FontSize="18"
                                       VerticalOptions="Center"/>
                                <Entry Text="{Binding Email}"
                                       Placeholder="Email Address"
                                       Keyboard="Email" WidthRequest="250"
                                       BackgroundColor="Transparent"
                                       TextColor="#111827"
                                       PlaceholderColor="#9CA3AF"
                                       VerticalTextAlignment="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Password Input -->
                        <Border Stroke="#E5E7EB" StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#F9FAFB"
                                Padding="16,4" HeightRequest="60">
                            <HorizontalStackLayout Spacing="16">
                                <Label Text="🔒" FontSize="18"
                                       VerticalOptions="Center"/>
                                <Entry Text="{Binding Password}"
                                       Placeholder="Password"
                                       IsPassword="True" WidthRequest="250"
                                       BackgroundColor="Transparent"
                                       TextColor="#111827"
                                       PlaceholderColor="#9CA3AF"
                                       VerticalTextAlignment="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <Label Text="Forgot password?" TextColor="#3498DB"
                               FontSize="13" FontAttributes="Bold"
                               HorizontalOptions="End"/>

                        <!-- Login Button -->
                        <Button Text="Login"
                                Command="{Binding LoginCommand}"
                                BackgroundColor="#3498DB" TextColor="White"
                                CornerRadius="12" HeightRequest="56"
                                FontAttributes="Bold" FontSize="16"
                                Margin="0,16,0,0"/>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="#3498DB"
                                           HorizontalOptions="Center"
                                           Margin="0,10,0,0"/>

                        <!-- Signup Link -->
                        <HorizontalStackLayout HorizontalOptions="Center"
                                               Spacing="4" Margin="0,20,0,0">
                            <Label Text="Don't have an account?"
                                   TextColor="#6B7280" FontSize="14"
                                   VerticalOptions="Center"/>
                            <Label Text="Sign Up" TextColor="#3498DB"
                                   FontAttributes="Bold" FontSize="14"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding GoToRegisterCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>