<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             x:Class="BillWise.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             BackgroundColor="#3498DB"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <Grid RowDefinitions="260,*" MinimumHeightRequest="700">

            <!-- Blue Header - Logo -->
            <VerticalStackLayout Grid.Row="0"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12">
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        WidthRequest="90" HeightRequest="90"
                        StrokeShape="RoundRectangle 22"
                        HorizontalOptions="Center">
                    <Label Text="BW" FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#3498DB"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <Label Text="BillWise"
                       FontSize="34" FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>
                <Label Text="Manage your invoices smartly"
                       FontSize="14" TextColor="#D6EAF8"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- White form -->
            <Border Grid.Row="1" BackgroundColor="White"
                    StrokeThickness="0" Padding="28,36,28,40">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="36,36,0,0"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <Label Text="Welcome Back"
                           FontSize="26" FontAttributes="Bold"
                           TextColor="#1A1A2E"/>
                    <Label Text="Sign in to your account"
                           FontSize="14" TextColor="#9CA3AF"
                           Margin="0,6,0,28"/>

                    <!-- Email -->
                    <Label Text="Email Address" FontSize="13"
                           FontAttributes="Bold" TextColor="#374151"
                           Margin="0,0,0,6"/>
                    <Border Stroke="#E5E7EB" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#F9FAFB"
                            Padding="16,0" HeightRequest="56"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding Email}"
                               Placeholder="your@email.com"
                               Keyboard="Email"
                               BackgroundColor="Transparent"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <!-- Password -->
                    <Label Text="Password" FontSize="13"
                           FontAttributes="Bold" TextColor="#374151"
                           Margin="0,0,0,6"/>
                    <Border Stroke="#E5E7EB" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#F9FAFB"
                            Padding="16,0" HeightRequest="56"
                            Margin="0,0,0,8">
                        <Entry Text="{Binding Password}"
                               Placeholder="Password"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <Label Text="Forgot password?"
                           TextColor="#3498DB" FontSize="13"
                           FontAttributes="Bold"
                           HorizontalOptions="End"
                           Margin="0,0,0,28"/>

                    <Button Text="Login"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="#3498DB" TextColor="White"
                            CornerRadius="14" HeightRequest="56"
                            FontAttributes="Bold" FontSize="16"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#3498DB"
                                       HorizontalOptions="Center"
                                       Margin="0,12,0,0"/>

                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="4" Margin="0,24,0,0">
                        <Label Text="Don't have an account?"
                               TextColor="#9CA3AF" FontSize="14"
                               VerticalOptions="Center"/>
                        <Label Text="Sign Up" TextColor="#3498DB"
                               FontAttributes="Bold" FontSize="14"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding GoToRegisterCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>