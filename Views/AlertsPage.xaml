<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:entities="clr-namespace:BillWise.Models.Entities"
             x:Class="BillWise.Views.AlertsPage"
             x:DataType="vm:AlertsViewModel"
             BackgroundColor="#FAFAFA"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="16,48,16,100">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Notifications" FontSize="26" FontAttributes="Bold" TextColor="#111827"/>
                        <Label Text="{Binding UnreadCount, StringFormat='You have {0} unread notifications'}"
                               FontSize="14" TextColor="#6B7280"/>
                    </VerticalStackLayout>

                    <!-- Bell icon with Badge -->
                    <Grid Grid.Column="1" WidthRequest="44" HeightRequest="44" VerticalOptions="Center">
                        <Border BackgroundColor="#EFF6FF" StrokeThickness="0"
                                StrokeShape="RoundRectangle 22"
                                WidthRequest="44" HeightRequest="44">
                            <Label Text="🔔" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        
                        <Border BackgroundColor="#EF4444" StrokeThickness="0" StrokeShape="RoundRectangle 10" 
                                WidthRequest="20" HeightRequest="20" HorizontalOptions="End" VerticalOptions="Start"
                                TranslationX="2" TranslationY="-2">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding UnreadCount}" Value="0">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{Binding UnreadCount}" TextColor="White" FontSize="10" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Notifications List -->
                <CollectionView ItemsSource="{Binding Notifications}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="entities:AppNotification">
                            <Border BackgroundColor="{Binding TypeCardBgColor}"
                                    Stroke="{Binding TypeBorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    Margin="0,0,0,12" Padding="16">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                    <!-- Dynamic icon per type -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="{Binding TypeIconBgColor}"
                                            StrokeShape="RoundRectangle 24"
                                            StrokeThickness="0"
                                            WidthRequest="48" HeightRequest="48"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding TypeIcon}" FontSize="20"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Content -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                        <Label Text="{Binding Title}"
                                               FontAttributes="Bold" FontSize="15"
                                               TextColor="{Binding TypeTitleColor}"/>
                                        <Label Text="{Binding Message}"
                                               FontSize="13" TextColor="#4B5563"
                                               LineBreakMode="WordWrap"/>
                                        <Label Text="{Binding SentAt, StringFormat='{0:dd MMM yyyy} at {0:HH:mm}'}"
                                               FontSize="12" TextColor="#9CA3AF"/>
                                    </VerticalStackLayout>

                                    <!-- Unread indicator dot -->
                                    <BoxView Grid.Column="2"
                                             WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                             Color="#EF4444"
                                             IsVisible="{Binding IsUnread}"
                                             VerticalOptions="Start" Margin="0,4,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <!-- Empty state -->
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                             Spacing="12" Padding="0,60,0,0">
                            <Label Text="🔕" FontSize="48" HorizontalOptions="Center"/>
                            <Label Text="No notifications yet" FontSize="16"
                                   TextColor="#9CA3AF" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>