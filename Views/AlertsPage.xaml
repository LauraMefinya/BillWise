<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:entities="clr-namespace:BillWise.Models.Entities"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.AlertsPage"
             x:DataType="vm:AlertsViewModel"
             BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="16,0,16,100">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding [Notifications], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               FontSize="26" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>
                        <Label Text="{Binding UnreadMessage}" FontSize="14" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                    </VerticalStackLayout>

                    <!-- Bell icon with Badge -->
                    <Grid Grid.Column="1" WidthRequest="44" HeightRequest="44" VerticalOptions="Center">
                        <Border BackgroundColor="{AppThemeBinding Light=#EFF6FF, Dark=#1E3A5F}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 22"
                                WidthRequest="44" HeightRequest="44">
                            <Label Text="🔔" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border BackgroundColor="#EF4444" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                WidthRequest="20" HeightRequest="20"
                                HorizontalOptions="End" VerticalOptions="Start"
                                TranslationX="2" TranslationY="-2"
                                IsVisible="{Binding HasUnread}">
                            <Label Text="{Binding UnreadCount}" TextColor="White"
                                   FontSize="10" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Mark all as read button (only visible if there are unread) -->
                <Border IsVisible="{Binding HasUnread}"
                        BackgroundColor="{AppThemeBinding Light=#EFF6FF, Dark=#1E3A5F}" StrokeThickness="0"
                        StrokeShape="RoundRectangle 8" Padding="12,8"
                        HorizontalOptions="End">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding MarkAllAsReadCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="{Binding [MarkAllRead], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           TextColor="#3498DB" FontSize="13" FontAttributes="Bold"/>
                </Border>

                <!-- Notifications List -->
                <CollectionView ItemsSource="{Binding Notifications}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="entities:AppNotification">
                            <Border BackgroundColor="{Binding TypeCardBgColor}"
                                    Stroke="{Binding TypeBorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    Margin="0,0,0,12" Padding="16">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AlertsViewModel}}, Path=MarkAsReadCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                    <!-- Icon -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="{Binding TypeIconBgColor}"
                                            StrokeShape="RoundRectangle 24"
                                            StrokeThickness="0"
                                            WidthRequest="48" HeightRequest="48"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding TypeIcon}" FontSize="20"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Content -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                        <Label Text="{Binding Title}"
                                               FontAttributes="Bold" FontSize="15"
                                               TextColor="{Binding TypeTitleColor}"/>
                                        <Label Text="{Binding Message}"
                                               FontSize="13" TextColor="{AppThemeBinding Light=#4B5563, Dark=#9CA3AF}"
                                               LineBreakMode="WordWrap"/>
                                        <Label Text="{Binding SentAt, StringFormat='{0:dd MMM yyyy}'}"
                                               FontSize="12" TextColor="#9CA3AF"/>
                                    </VerticalStackLayout>

                                    <!-- Unread dot -->
                                    <BoxView Grid.Column="2"
                                             WidthRequest="10" HeightRequest="10"
                                             CornerRadius="5" Color="#EF4444"
                                             IsVisible="{Binding IsUnread}"
                                             VerticalOptions="Start" Margin="0,4,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <!-- Empty state -->
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                             Spacing="12" Padding="0,60,0,0">
                            <Label Text="🔕" FontSize="48" HorizontalOptions="Center"/>
                            <Label Text="{Binding [NoNotifications], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   FontSize="16" TextColor="#9CA3AF" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading indicator -->
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#3498DB"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
    </Grid>
</ContentPage>
