<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:entities="clr-namespace:BillWise.Models.Entities"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             x:Class="BillWise.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             BackgroundColor="#3498DB"
             Shell.BackgroundColor="#3498DB"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- Blue Header Section -->
                <Grid BackgroundColor="#3498DB" Padding="20,40,20,60">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="{Binding [HomeGreeting], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="26" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="{Binding [ManageBills], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="14" TextColor="#E0F2FE" Margin="0,-12,0,0"/>

                        <Border BackgroundColor="#2980B9" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="20" Margin="0,10,0,0">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding [TotalToPay], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="14" TextColor="#E0F2FE"/>
                                <HorizontalStackLayout Spacing="4" HorizontalOptions="Start">
                                    <Label Text="{Binding TotalToPay, StringFormat='{0:N0}'}" FontSize="28" FontAttributes="Bold" TextColor="White"/>
                                    <Label Text="{Binding CurrencySymbol}" FontSize="28" FontAttributes="Bold" TextColor="White"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <!-- Main Content Area -->
                <VerticalStackLayout BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}" Spacing="16" Padding="16,0,16,100" Margin="0,-30,0,0">

                    <!-- Overlapping Cards: Paid / To Pay -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <!-- Paid -->
                        <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                            <VerticalStackLayout Spacing="8">
                                <Border BackgroundColor="#D1FAE5" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="6" HorizontalOptions="Start">
                                    <Label Text="📉" FontSize="16"/>
                                </Border>
                                <Label Text="{Binding [Paid], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                                <Label Text="{Binding TotalPaid, StringFormat='{0:N0}'}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>
                                <Label Text="{Binding CurrencySymbol}" FontSize="10" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" Margin="0,-4,0,0"/>
                            </VerticalStackLayout>
                        </Border>
                        <!-- To Pay -->
                        <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                            <VerticalStackLayout Spacing="8">
                                <Border BackgroundColor="#FEE2E2" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="6" HorizontalOptions="Start">
                                    <Label Text="📈" FontSize="16"/>
                                </Border>
                                <Label Text="{Binding [ToPay], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                                <Label Text="{Binding TotalToPay, StringFormat='{0:N0}'}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>
                                <Label Text="{Binding CurrencySymbol}" FontSize="10" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" Margin="0,-4,0,0"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Monthly Expenses Graph -->
                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 12" Padding="16" Margin="0,10,0,0">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="{Binding [MonthlyExpenses], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>
                            <lvc:CartesianChart Series="{Binding BarSeries}"
                                                XAxes="{Binding XAxes}"
                                                YAxes="{Binding YAxes}"
                                                HeightRequest="200"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Overdue Alert -->
                    <Border IsVisible="{Binding HasOverdueInvoices}" BackgroundColor="#FEF2F2" Stroke="#FECACA" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                            <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Text="🕒" FontSize="24" VerticalOptions="Center"/>
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding [OverdueInvoices], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="#B91C1C" FontSize="16" FontAttributes="Bold"/>
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding OverdueMessage}" TextColor="#DC2626" FontSize="13"/>
                        </Grid>
                    </Border>

                    <!-- Upcoming Invoices Header -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,16,0,8">
                        <Label Grid.Column="0" Text="{Binding [UpcomingInvoices], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding [ViewAll], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="#3498DB" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="End">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToInvoicesFallbackCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Invoices List -->
                    <CollectionView ItemsSource="{Binding RecentInvoices}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="entities:Invoice">
                                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16" Margin="0,0,0,12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=GoToDetailsCommand}" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                        <!-- Category Icon -->
                                        <Border Grid.Column="0" BackgroundColor="{Binding CategoryIconBackgroundColor}" StrokeThickness="0" StrokeShape="RoundRectangle 12" WidthRequest="48" HeightRequest="48" HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label Text="{Binding CategoryIcon}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>

                                        <!-- Invoice Details -->
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="📅" FontSize="12" TextColor="#9CA3AF" VerticalOptions="Center"/>
                                                <Label Text="{Binding DueDate, StringFormat='{0:dd MMM. yyyy}'}" FontSize="13" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>

                                            <!-- Status Tag -->
                                            <Border BackgroundColor="{Binding StatusBackgroundColor}" StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="8,4" HorizontalOptions="Start">
                                                <Label Text="{Binding StatusText}" TextColor="{Binding StatusTextColor}" FontSize="11" FontAttributes="Bold"/>
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- Amount & Arrow -->
                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="8">
                                            <Label Text="{Binding FormattedAmount}" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" HorizontalOptions="End"/>
                                            <Label Text=">" FontSize="16" TextColor="#9CA3AF" HorizontalOptions="End"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Floating Action Button -->
        <ImageButton BackgroundColor="#3498DB" CornerRadius="30"
                     WidthRequest="60" HeightRequest="60" Padding="15"
                     HorizontalOptions="End" VerticalOptions="End" Margin="0,0,20,80"
                     Clicked="OnFabClicked"
                     Shadow="{Shadow Default}">
            <ImageButton.Source>
                <FontImageSource Glyph="+" Color="White" Size="28" />
            </ImageButton.Source>
        </ImageButton>

    </Grid>
</ContentPage>
