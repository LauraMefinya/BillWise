<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.EditInvoicePage"
             x:DataType="vm:EditInvoiceViewModel"
             BackgroundColor="#FAFAFA"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        
        <!-- Custom Header from mockup -->
        <Border Grid.Row="0" BackgroundColor="White" StrokeThickness="0" Padding="0" Margin="0">
            <VerticalStackLayout>
                <Grid ColumnDefinitions="Auto, *" Padding="20,16,20,16">
                    <!-- Back arrow -->
                    <Label Text="←" FontSize="22" FontAttributes="Bold" TextColor="#001F3F" VerticalOptions="Center" Margin="0,0,16,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Grid.Column="1" Text="{Binding [EditInvoice], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="20" FontAttributes="Bold" TextColor="#001F3F" VerticalOptions="Center"/>
                </Grid>
                <!-- Separator -->
                <BoxView HeightRequest="1" Color="#E5E7EB"/>
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Padding="16,10,16,30">

            <!-- Top Action Buttons -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12" Margin="0,0,0,16">
                <!-- Scan Button -->
                <Border Grid.Column="0" Stroke="#3498DB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="0,16">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="📷" FontSize="24" TextColor="#3498DB" HorizontalOptions="Center"/>
                        <Label Text="{Binding [Scan], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#3498DB" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Voice Button -->
                <Border Grid.Column="1" Stroke="#E74C3C" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="0,16">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="🎤" FontSize="24" TextColor="#E74C3C" HorizontalOptions="Center"/>
                        <Label Text="{Binding [Voice], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#E74C3C" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Location Button -->
                <Border Grid.Column="2" Stroke="#2ECC71" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="0,16">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="📍" FontSize="24" TextColor="#2ECC71" HorizontalOptions="Center"/>
                        <Label Text="{Binding [Location], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#2ECC71" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Invoice Name -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,4" HeightRequest="65">
                <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                    <Label Text="{Binding [InvoiceName], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <Entry Text="{Binding InvoiceName, Mode=TwoWay}" Placeholder="e.g., ENEO, CAMWATER..." 
                           PlaceholderColor="#9CA3AF" BackgroundColor="Transparent" 
                           TextColor="Black" Margin="0,-4,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- Amount -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,4" HeightRequest="65">
                <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                    <Label Text="{Binding [Amount], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <Entry Text="{Binding AmountText, Mode=TwoWay}" Placeholder="e.g., 25000" Keyboard="Numeric"
                           PlaceholderColor="#9CA3AF" BackgroundColor="Transparent" 
                           TextColor="Black" Margin="0,-4,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- Due Date -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding [DueDate], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <Grid>
                        <!-- Real hidden picker to trigger native dialog, TextColor transparent prevents it from showing its text -->
                        <DatePicker Date="{Binding DueDate}" TextColor="Transparent" BackgroundColor="Transparent" DateSelected="OnDateSelected"/>
                        
                        <!-- Visual Fake Picker text -->
                        <Label Text="{Binding DueDateText}" TextColor="{Binding DueDateColor}" VerticalOptions="Center" InputTransparent="True"/>
                        
                        <!-- Calendar Icon on the right -->
                        <Label Text="📅" HorizontalOptions="End" VerticalOptions="Center" FontSize="16" InputTransparent="True"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Category -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12"
                    BackgroundColor="White" Padding="16,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding [Category], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8"
                            BackgroundColor="#F9FAFB" Padding="12,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenCategoryPickerCommand}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding SelectedCategoryLabel}"
                                   TextColor="Black" VerticalOptions="Center" FontSize="14"/>
                            <Label Grid.Column="1" Text="›" FontSize="22" TextColor="#9CA3AF"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Payment Method -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding [PaymentMethod], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <Picker SelectedItem="{Binding PaymentMethod}" Title="{Binding [SelectMethod], Source={x:Static strings:LocalizationResourceManager.Instance}}" TitleColor="#9CA3AF" BackgroundColor="Transparent" TextColor="Black">
                        <Picker.Items>
                            <x:String>Bank Transfer</x:String>
                            <x:String>PayPal</x:String>
                            <x:String>Google Pay</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <!-- Notes -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding [Notes], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <Editor Text="{Binding Notes}" Placeholder="{Binding [AddNotes], Source={x:Static strings:LocalizationResourceManager.Instance}}" PlaceholderColor="#9CA3AF" HeightRequest="80"
                            BackgroundColor="Transparent" AutoSize="TextChanges" TextColor="Black"/>
                </VerticalStackLayout>
            </Border>

            <!-- Save Button with Floppy Disk icon -->
            <Border BackgroundColor="#3498DB" StrokeThickness="0" StrokeShape="RoundRectangle 8" HeightRequest="50" Margin="0,10,0,0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SaveInvoiceCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                    <Grid WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                        <Path Data="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2zM17 21v-8H7v8M7 3v5h8V3"
                              Stroke="White" StrokeThickness="2" StrokeLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" 
                              Aspect="Uniform"/>
                    </Grid>
                    <Label Text="{Binding [SaveChanges], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="White" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
    </Grid>
</ContentPage>
