<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.ResetPasswordPage"
             x:DataType="vm:ResetPasswordViewModel"
             BackgroundColor="#3498DB"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <VerticalStackLayout Padding="32,60,32,40" Spacing="12" HorizontalOptions="Center">
                <Label Text="🔐" FontSize="48" HorizontalOptions="Center"/>
                <Label Text="{Binding [ResetPassword], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                       FontSize="26" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                <Label Text="{Binding [ResetPasswordDesc], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                       FontSize="14" TextColor="#E0F2FE" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- Card -->
            <Border BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}"
                    StrokeThickness="0" StrokeShape="RoundRectangle 30,30,0,0"
                    Padding="24,32,24,40">
                <VerticalStackLayout Spacing="16">

                    <!-- New Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding [NewPasswordLabel], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#374151, Dark=#9CA3AF}"/>
                        <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#374151}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                                Padding="14,0" HeightRequest="52">
                            <Entry Text="{Binding NewPassword, Mode=TwoWay}"
                                   IsPassword="True"
                                   Placeholder="••••••••"
                                   PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                                   VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Confirm Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding [ConfirmPassword], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#374151, Dark=#9CA3AF}"/>
                        <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#374151}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                                Padding="14,0" HeightRequest="52">
                            <Entry Text="{Binding ConfirmPassword, Mode=TwoWay}"
                                   IsPassword="True"
                                   Placeholder="••••••••"
                                   PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                                   VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Submit Button -->
                    <Button Text="{Binding [ResetPassword], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                            Command="{Binding ResetPasswordCommand}"
                            BackgroundColor="#3498DB" TextColor="White"
                            CornerRadius="12" HeightRequest="54"
                            FontAttributes="Bold" FontSize="16"
                            Margin="0,12,0,0"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#3498DB" HorizontalOptions="Center"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
