<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             x:Class="BillWise.Views.InvoicesPage"
             x:DataType="vm:InvoicesViewModel"
             BackgroundColor="#FAFAFA"
             Shell.NavBarIsVisible="False">
    <Grid>
        <VerticalStackLayout Spacing="16" Padding="16,40,16,100">
            <!-- Header -->
            <Label Text="My Invoices" FontSize="26" FontAttributes="Bold" TextColor="#111827"/>

            <!-- Search Bar -->
            <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="10,0">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Text="🔍" FontSize="18" TextColor="#9CA3AF" VerticalOptions="Center"/>
                    <Entry Grid.Column="1" Placeholder="Search invoice..." PlaceholderColor="#9CA3AF" 
                           Text="{Binding SearchQuery}" ClearButtonVisibility="WhileEditing"
                           BackgroundColor="Transparent"/>
                </Grid>
            </Border>

            <!-- Filters -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">
                    <!-- Filter: All -->
                    <Border StrokeThickness="0" BackgroundColor="#2196F3" StrokeShape="RoundRectangle 8" Padding="16,8">
                        <Label Text="All" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadDataCommand}" CommandParameter="All"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Filter: Paid -->
                    <Border StrokeThickness="0" BackgroundColor="#F3F4F6" StrokeShape="RoundRectangle 8" Padding="16,8">
                        <Label Text="Paid" TextColor="#4B5563" FontSize="13"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadDataCommand}" CommandParameter="Paid"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Filter: Pending -->
                    <Border StrokeThickness="0" BackgroundColor="#F3F4F6" StrokeShape="RoundRectangle 8" Padding="16,8">
                        <Label Text="Pending" TextColor="#4B5563" FontSize="13"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadDataCommand}" CommandParameter="Pending"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Filter: Overdue -->
                    <Border StrokeThickness="0" BackgroundColor="#F3F4F6" StrokeShape="RoundRectangle 8" Padding="16,8">
                        <Label Text="Overdue" TextColor="#4B5563" FontSize="13"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadDataCommand}" CommandParameter="Overdue"/>
                        </Border.GestureRecognizers>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Invoices List -->
            <CollectionView ItemsSource="{Binding Invoices}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1"
                                StrokeShape="RoundRectangle 12" Margin="0,6" Padding="16">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border Grid.Column="0" BackgroundColor="#F3F4F6" StrokeShape="RoundRectangle 12" 
                                        StrokeThickness="0" Padding="8" WidthRequest="48" HeightRequest="48" 
                                        VerticalOptions="Start">
                                    <Label Text="{Binding CategoryIcon}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#111827"/>
                                    <Label Text="{Binding DueDate, StringFormat='📅 {0:dd MMM yyyy}'}" FontSize="13" TextColor="#6B7280"/>
                                    
                                    <Border StrokeThickness="0" Padding="8,4" StrokeShape="RoundRectangle 8" 
                                            HorizontalOptions="Start" BackgroundColor="{Binding StatusBadgeColor}">
                                        <Label Text="{Binding StatusLabel}" FontSize="11" TextColor="{Binding StatusTextColor}" FontAttributes="Bold"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Start" Margin="0,4,0,0">
                                    <Label Text="{Binding AmountFormatted}" FontAttributes="Bold" FontSize="16" TextColor="#111827" HorizontalOptions="End"/>
                                    <Label Text="❯" FontSize="14" TextColor="#9CA3AF" HorizontalOptions="End"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Floating Action Button -->
        <ImageButton BackgroundColor="#3498DB" CornerRadius="30"
                     WidthRequest="60" HeightRequest="60" Padding="15"
                     HorizontalOptions="End" VerticalOptions="End" Margin="20,20,20,30"
                     Clicked="OnFabClicked">
             <ImageButton.Source>
                <FontImageSource Glyph="+" Color="White" Size="24" />
            </ImageButton.Source>
        </ImageButton>
    </Grid>
</ContentPage>