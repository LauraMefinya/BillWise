<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:entities="clr-namespace:BillWise.Models.Entities"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.InvoicesPage"
             x:DataType="vm:InvoicesViewModel"
             BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}"
             Shell.NavBarIsVisible="False">
    <Grid>
        <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16,0,16,0" RowSpacing="16">

            <!-- Header -->
            <Label Grid.Row="0"
                   Text="{Binding [MyInvoices], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                   FontSize="26" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>

            <!-- Search Bar -->
            <Border Grid.Row="1"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Padding="10,0">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Text="🔍" FontSize="18" TextColor="#9CA3AF" VerticalOptions="Center"/>
                    <Entry Grid.Column="1"
                           Placeholder="{Binding [SearchInvoice], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           PlaceholderColor="#9CA3AF"
                           TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                           Text="{Binding SearchQuery}" ClearButtonVisibility="WhileEditing"
                           BackgroundColor="Transparent"/>
                </Grid>
            </Border>

            <!-- Filters -->
            <ScrollView Grid.Row="2" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">
                    <!-- Filter: All -->
                    <Border StrokeThickness="0" BackgroundColor="{Binding AllChipBackground}" StrokeShape="RoundRectangle 8" Padding="16,8">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{Binding [All], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{Binding AllChipTextColor}" FontSize="13" FontAttributes="Bold"/>
                            <Label Text="{Binding AllCount, StringFormat='({0})'}" TextColor="{Binding AllChipTextColor}" FontSize="13" FontAttributes="Bold"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadDataCommand}" CommandParameter="All"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Filter: Paid -->
                    <Border StrokeThickness="0" BackgroundColor="{Binding PaidChipBackground}" StrokeShape="RoundRectangle 8" Padding="16,8">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{Binding [Paid], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{Binding PaidChipTextColor}" FontSize="13"/>
                            <Label Text="{Binding PaidCount, StringFormat='({0})'}" TextColor="{Binding PaidChipTextColor}" FontSize="13"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadDataCommand}" CommandParameter="Paid"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Filter: Pending -->
                    <Border StrokeThickness="0" BackgroundColor="{Binding PendingChipBackground}" StrokeShape="RoundRectangle 8" Padding="16,8">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{Binding [Pending], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{Binding PendingChipTextColor}" FontSize="13"/>
                            <Label Text="{Binding PendingCount, StringFormat='({0})'}" TextColor="{Binding PendingChipTextColor}" FontSize="13"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadDataCommand}" CommandParameter="Pending"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Filter: Overdue -->
                    <Border StrokeThickness="0" BackgroundColor="{Binding OverdueChipBackground}" StrokeShape="RoundRectangle 8" Padding="16,8">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{Binding [Overdue], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{Binding OverdueChipTextColor}" FontSize="13"/>
                            <Label Text="{Binding OverdueCount, StringFormat='({0})'}" TextColor="{Binding OverdueChipTextColor}" FontSize="13"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadDataCommand}" CommandParameter="Overdue"/>
                        </Border.GestureRecognizers>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Invoices List -->
            <CollectionView Grid.Row="3" ItemsSource="{Binding Invoices}" SelectionMode="None">
                <CollectionView.Footer>
                    <ContentView HeightRequest="100"/>
                </CollectionView.Footer>
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16" Margin="0,50,0,0">
                        <Label Text="📄" FontSize="60" HorizontalOptions="Center" TextColor="#D1D5DB"/>
                        <Label Text="{Binding [NoInvoicesFound], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>
                        <Label Text="{Binding [StartAdding], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="14" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="entities:Invoice">
                        <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 12" Margin="0,6" Padding="16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InvoicesViewModel}}, Path=GoToDetailsCommand}" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <!-- Category icon -->
                                <Border Grid.Column="0"
                                        BackgroundColor="{Binding CategoryIconBackgroundColor}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                        WidthRequest="46" HeightRequest="46"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding CategoryIcon}" FontSize="22"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>
                                    <Label Text="{Binding CategoryText}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="📅" FontSize="12" TextColor="#9CA3AF" VerticalOptions="Center"/>
                                        <Label Text="{Binding DueDate, StringFormat='{0:dd MMM. yyyy}'}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Border BackgroundColor="{Binding StatusBackgroundColor}" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12" Padding="8,4" HorizontalOptions="Start" Margin="0,4,0,0">
                                        <Label Text="{Binding StatusText}" TextColor="{Binding StatusTextColor}"
                                               FontSize="10" FontAttributes="Bold"/>
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2" Spacing="8" HorizontalOptions="End" VerticalOptions="Center">
                                    <Label Text="{Binding FormattedAmount}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" HorizontalOptions="End"/>
                                    <Label Text="›" FontSize="20" TextColor="#9CA3AF" HorizontalOptions="End"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <!-- Floating Action Button -->
        <ImageButton BackgroundColor="#2196F3" CornerRadius="30"
                     WidthRequest="60" HeightRequest="60" Padding="15"
                     HorizontalOptions="End" VerticalOptions="End" Margin="20,20,20,30"
                     Clicked="OnFabClicked">
            <ImageButton.Source>
                <FontImageSource Glyph="+" Color="White" Size="24" />
            </ImageButton.Source>
        </ImageButton>

    </Grid>
</ContentPage>
