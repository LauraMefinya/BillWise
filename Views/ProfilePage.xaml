<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#121212}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Blue Header -->
            <Grid BackgroundColor="#3498DB" Padding="20,48,20,24">
                <!-- Pencil top-right -->
                <Button Text="✏️"
                        Command="{Binding PickProfilePhotoCommand}"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="18"
                        HorizontalOptions="End"
                        VerticalOptions="Start"
                        WidthRequest="44" HeightRequest="44"
                        Padding="0"
                        Margin="0,-4,-4,0"/>

                <!-- Horizontal: photo + name/email -->
                <HorizontalStackLayout Spacing="16" VerticalOptions="Center">
                    <Border StrokeShape="RoundRectangle 40"
                            WidthRequest="75" HeightRequest="75"
                            BackgroundColor="#2980B9"
                            Stroke="White" StrokeThickness="2.5">
                        <Grid>
                            <Label Text="👤" FontSize="36"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding HasNoProfilePhoto}"/>
                            <Image Source="{Binding ProfilePhoto}"
                                   Aspect="AspectFill"
                                   IsVisible="{Binding HasProfilePhoto}"/>
                        </Grid>
                    </Border>
                    <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                        <Label Text="{Binding UserName}"
                               TextColor="White" FontSize="20"
                               FontAttributes="Bold"/>
                        <Label Text="{Binding UserEmail}"
                               TextColor="White" FontSize="13"
                               Opacity="0.85"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Grid>

            <VerticalStackLayout Spacing="16" Padding="16,20,16,64">

                <!-- Stats Row -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                        Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="8,14">
                    <Grid ColumnDefinitions="*,Auto,*,Auto,*,Auto,*">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding TotalInvoices}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding [TotalInvoices], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   FontSize="10" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="1" WidthRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                                 VerticalOptions="FillAndExpand"/>
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding PaidInvoices}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="#10B981"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding [Paid], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   FontSize="10" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="3" WidthRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                                 VerticalOptions="FillAndExpand"/>
                        <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding PendingInvoices}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="#F59E0B"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding [Pending], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   FontSize="10" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="5" WidthRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                                 VerticalOptions="FillAndExpand"/>
                        <VerticalStackLayout Grid.Column="6" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding OverdueInvoices}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="#EF4444"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding [Overdue], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   FontSize="10" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Settings Section Label -->
                <Label Text="{Binding [Settings], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                       Margin="4,0,0,0"/>

                <!-- Settings Card -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                        Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14">
                    <VerticalStackLayout>

                        <!-- Currency -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12">
                            <Border Grid.Column="0" BackgroundColor="#D1FAE5"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                    WidthRequest="40" HeightRequest="40"
                                    VerticalOptions="Center">
                                <Label Text="💰" FontSize="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{Binding [Currency], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                                   FontSize="15" VerticalOptions="Center"
                                   Margin="14,0,0,0"/>
                            <Picker Grid.Column="2"
                                    ItemsSource="{Binding CurrencyOptions}"
                                    SelectedItem="{Binding SelectedCurrency}"
                                    TextColor="{AppThemeBinding Light=#3498DB, Dark=#60A5FA}"
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    VerticalOptions="Center"
                                    WidthRequest="80"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D3D}"
                                 Margin="16,0"/>

                        <!-- Manage Categories -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,16">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ManageCategoriesCommand}"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0" BackgroundColor="#FEF3C7"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                    WidthRequest="40" HeightRequest="40"
                                    VerticalOptions="Center">
                                <Label Text="🏷️" FontSize="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{Binding [ManageCategories], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                                   FontSize="15" VerticalOptions="Center"
                                   Margin="14,0,0,0"/>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="24" TextColor="#9CA3AF"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D3D}"
                                 Margin="16,0"/>

                        <!-- Dark Mode -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,6">
                            <Border Grid.Column="0" BackgroundColor="#E0F2FE"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                    WidthRequest="40" HeightRequest="40"
                                    VerticalOptions="Center">
                                <Label Text="🌙" FontSize="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{Binding [DarkMode], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                                   FontSize="15" VerticalOptions="Center"
                                   Margin="14,0,0,0"/>
                            <Switch Grid.Column="2"
                                    IsToggled="{Binding DarkModeEnabled}"
                                    OnColor="#3498DB"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D3D}"
                                 Margin="16,0"/>

                        <!-- Notifications -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,6">
                            <Border Grid.Column="0" BackgroundColor="#FFEDD5"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                    WidthRequest="40" HeightRequest="40"
                                    VerticalOptions="Center">
                                <Label Text="🔔" FontSize="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{Binding [Notifications], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                                   FontSize="15" VerticalOptions="Center"
                                   Margin="14,0,0,0"/>
                            <Switch Grid.Column="2"
                                    IsToggled="{Binding NotificationsEnabled}"
                                    OnColor="#3498DB"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D2D3D}"
                                 Margin="16,0"/>

                        <!-- Reminder Days -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,6">
                            <Border Grid.Column="0" BackgroundColor="#FFFBEB"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                    WidthRequest="40" HeightRequest="40"
                                    VerticalOptions="Center">
                                <Label Text="⏳" FontSize="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{Binding [ReminderDays], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                   TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                                   FontSize="15" VerticalOptions="Center"
                                   Margin="14,0,0,0"/>
                            <Border Grid.Column="2" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" 
                                    StrokeThickness="1" StrokeShape="RoundRectangle 8" 
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#252836}" 
                                    WidthRequest="60" HeightRequest="36" VerticalOptions="Center">
                                <Entry Text="{Binding ReminderDays}" Keyboard="Numeric" 
                                       BackgroundColor="Transparent" 
                                       TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" 
                                       HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Account Settings Row -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                        Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,16">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToAccountSettingsCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0" BackgroundColor="#DBEAFE"
                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                WidthRequest="40" HeightRequest="40"
                                VerticalOptions="Center">
                            <Label Text="⚙️" FontSize="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="{Binding [AccountSettings], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                               TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                               FontSize="15" VerticalOptions="Center"
                               Margin="14,0,0,0"/>
                        <Label Grid.Column="2" Text="›"
                               FontSize="24" TextColor="#9CA3AF"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#3498DB"
                                   HorizontalOptions="Center"
                                   Margin="0,8,0,0"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
