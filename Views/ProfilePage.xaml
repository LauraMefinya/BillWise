<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="#FAFAFA"
             Shell.NavBarIsVisible="False">
             
    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <!-- Header section (Blue Background) -->
            <Grid BackgroundColor="#3498DB" Padding="20,40,20,40">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Border StrokeShape="RoundRectangle 40" WidthRequest="80" HeightRequest="80" BackgroundColor="#2980B9" StrokeThickness="0" HorizontalOptions="Center">
                        <Label Text="👤" FontSize="36" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="{Binding UserName}" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="{Binding UserEmail}" TextColor="White" FontSize="14" Margin="0,-12,0,0" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Spacing="24" Padding="16,24,16,60" Margin="0,-30,0,0">
                
                <!-- Summary Card -->
                <Border BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="20">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="16" RowSpacing="24">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="{Binding TotalInvoices}" FontSize="24" FontAttributes="Bold" TextColor="#111827" HorizontalOptions="Center"/>
                            <Label Text="{Binding [TotalInvoices], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="{Binding PaidInvoices}" FontSize="24" FontAttributes="Bold" TextColor="#10B981" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Paid], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="{Binding PendingInvoices}" FontSize="24" FontAttributes="Bold" TextColor="#F59E0B" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Pending], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="{Binding OverdueInvoices}" FontSize="24" FontAttributes="Bold" TextColor="#EF4444" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Overdue], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Label Text="{Binding [Settings], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="18" FontAttributes="Bold" TextColor="#111827"/>

                <!-- Settings Display List -->
                
                <!-- Currency -->
                <Border BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#D1FAE5" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="💲" FontSize="16"/>
                        </Border>
                        <Label Grid.Column="1" Text="{Binding [Currency], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="#6B7280" FontSize="14" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Label Grid.Column="2" Text="{Binding SelectedCurrency}" TextColor="#111827" FontAttributes="Bold" FontSize="14" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Language -->
                <Border BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#DBEAFE" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="🌐" FontSize="16"/>
                        </Border>
                        <Label Grid.Column="1" Text="{Binding [Language], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="#6B7280" FontSize="14" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Label Grid.Column="2" Text="{Binding SelectedLanguage}" TextColor="#111827" FontAttributes="Bold" FontSize="14" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Notifications -->
                <Border BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#FFEDD5" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="🔔" FontSize="16"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="12,0,0,0" Spacing="2">
                            <Label Text="{Binding [Notifications], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="#6B7280" FontSize="14"/>
                            <Label Text="{Binding [Enabled], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontAttributes="Bold" TextColor="#111827" FontSize="14"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Feedback -->
                <Border BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#F3E8FF" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="📳" FontSize="16"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="12,0,0,0" Spacing="2">
                            <Label Text="{Binding [HapticFeedback], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="#6B7280" FontSize="14"/>
                            <Label Text="{Binding [Enabled], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontAttributes="Bold" TextColor="#111827" FontSize="14"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Manage Categories -->
                <Border BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ManageCategoriesCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#FEF3C7" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="🏷️" FontSize="16"/>
                        </Border>
                        <Label Grid.Column="1" Text="{Binding [ManageCategories], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="#6B7280" FontSize="14" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#9CA3AF" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Buttons -->
                <Button Text="{Binding [EditProfile], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding GoToEditProfileCommand}" BackgroundColor="#3498DB" TextColor="White" CornerRadius="8" FontAttributes="Bold" HeightRequest="50"/>
                
                <Button Text="{Binding [ExportData], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding ExportDataCommand}" BackgroundColor="#2ECC71" TextColor="White" CornerRadius="8" FontAttributes="Bold" HeightRequest="50"/>
                
                <Button Text="{Binding [ClearAllData], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding ClearAllDataCommand}" BackgroundColor="#E74C3C" TextColor="White" CornerRadius="8" FontAttributes="Bold" HeightRequest="50" Margin="0,0,0,10"/>

                <Button Text="{Binding [Logout], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding LogoutCommand}" BackgroundColor="Transparent" TextColor="#E74C3C" BorderColor="#E74C3C" BorderWidth="1" CornerRadius="8" FontAttributes="Bold" HeightRequest="50" Margin="0,0,0,20"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>