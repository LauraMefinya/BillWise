<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <!-- Header section (Blue Background) -->
            <Grid BackgroundColor="#3498DB" Padding="20,40,20,40">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Border StrokeShape="RoundRectangle 40" WidthRequest="80" HeightRequest="80" BackgroundColor="#2980B9" StrokeThickness="0" HorizontalOptions="Center">
                        <Label Text="👤" FontSize="36" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="{Binding UserName}" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="{Binding UserEmail}" TextColor="White" FontSize="14" Margin="0,-12,0,0" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Spacing="24" Padding="16,24,16,60">

                <!-- Summary Card -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="20">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="16" RowSpacing="24">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="{Binding TotalInvoices}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" HorizontalOptions="Center"/>
                            <Label Text="{Binding [TotalInvoices], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="{Binding PaidInvoices}" FontSize="24" FontAttributes="Bold" TextColor="#10B981" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Paid], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="{Binding PendingInvoices}" FontSize="24" FontAttributes="Bold" TextColor="#F59E0B" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Pending], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="{Binding OverdueInvoices}" FontSize="24" FontAttributes="Bold" TextColor="#EF4444" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Overdue], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Label Text="{Binding [Settings], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>

                <!-- Currency -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#D1FAE5" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="💲" FontSize="16"/>
                        </Border>
                        <Label Grid.Column="1" Text="{Binding [Currency], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="14" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Label Grid.Column="2" Text="{Binding SelectedCurrency}" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" FontAttributes="Bold" FontSize="14" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Language -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#DBEAFE" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="🌐" FontSize="16"/>
                        </Border>
                        <Label Grid.Column="1" Text="{Binding [Language], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="14" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Label Grid.Column="2" Text="{Binding SelectedLanguage}" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" FontAttributes="Bold" FontSize="14" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Notifications -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#FFEDD5" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="🔔" FontSize="16"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="12,0,0,0" Spacing="2">
                            <Label Text="{Binding [Notifications], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="14"/>
                            <Label Text="{Binding NotificationsStatusText}" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" FontSize="14"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Haptic Feedback -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#F3E8FF" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="📳" FontSize="16"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="12,0,0,0" Spacing="2">
                            <Label Text="{Binding [HapticFeedback], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="14"/>
                            <Label Text="{Binding HapticStatusText}" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" FontSize="14"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Dark Mode Toggle -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#E0F2FE" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="🌙" FontSize="16"/>
                        </Border>
                        <Label Grid.Column="1" Text="{Binding [DarkMode], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Switch Grid.Column="2" IsToggled="{Binding DarkModeEnabled}" OnColor="#3498DB" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Manage Categories -->
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ManageCategoriesCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" BackgroundColor="#FEF3C7" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10" VerticalOptions="Center">
                            <Label Text="🏷️" FontSize="16"/>
                        </Border>
                        <Label Grid.Column="1" Text="{Binding [ManageCategories], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" FontSize="14" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#9CA3AF" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Buttons -->
                <Button Text="{Binding [EditProfile], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                        Command="{Binding GoToEditProfileCommand}"
                        BackgroundColor="#3498DB" TextColor="White"
                        CornerRadius="10" FontAttributes="Bold" HeightRequest="52"/>

                <!-- Export + Clear side by side -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="#2ECC71" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 10">
                        <Button Text="{Binding [ExportData], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                Command="{Binding ExportDataCommand}"
                                BackgroundColor="Transparent" TextColor="#2ECC71"
                                CornerRadius="10" FontAttributes="Bold" HeightRequest="52"/>
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" Stroke="#E74C3C" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 10">
                        <Button Text="{Binding [ClearAllData], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                Command="{Binding ClearAllDataCommand}"
                                BackgroundColor="Transparent" TextColor="#E74C3C"
                                CornerRadius="10" FontAttributes="Bold" HeightRequest="52"/>
                    </Border>
                </Grid>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#3498DB"
                                   HorizontalOptions="Center"/>

                <Button Text="{Binding [Logout], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="Transparent" TextColor="#E74C3C"
                        BorderColor="#E74C3C" BorderWidth="1.5"
                        CornerRadius="10" FontAttributes="Bold" HeightRequest="52"
                        Margin="0,4,0,20"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
