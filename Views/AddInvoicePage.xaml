<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:entities="clr-namespace:BillWise.Models.Entities"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.AddInvoicePage"
             x:DataType="vm:AddInvoiceViewModel"
             Title="New Invoice"
             BackgroundColor="#FAFAFA">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16,10,16,30">

            <!-- Top Action Buttons -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12" Margin="0,0,0,16">
                <!-- Scan Button -->
                <Border Grid.Column="0" Stroke="#3498DB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="0,16">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="📷" FontSize="24" TextColor="#3498DB" HorizontalOptions="Center"/>
                        <Label Text="Scan" FontSize="12" TextColor="#3498DB" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Voice Button -->
                <Border Grid.Column="1" Stroke="#E74C3C" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="0,16">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="🎤" FontSize="24" TextColor="#E74C3C" HorizontalOptions="Center"/>
                        <Label Text="Voice" FontSize="12" TextColor="#E74C3C" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Location Button -->
                <Border Grid.Column="2" Stroke="#2ECC71" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="0,16">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="📍" FontSize="24" TextColor="#2ECC71" HorizontalOptions="Center"/>
                        <Label Text="Location" FontSize="12" TextColor="#2ECC71" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Label Text="{Binding [NewInvoice], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" 
                   TextColor="#111827" Margin="0,8,0,0"/>

            <!-- Invoice Name -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding [InvoiceName], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <Entry Text="{Binding InvoiceName}" Placeholder="e.g., ENEO, CAMWATER..." 
                           BackgroundColor="Transparent" ClearButtonVisibility="WhileEditing"
                           TextColor="#212121"/>
                </VerticalStackLayout>
            </Border>

            <!-- Amount -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding [Amount], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <Entry Text="{Binding AmountText}" Placeholder="e.g., 25000" Keyboard="Numeric"
                           BackgroundColor="Transparent" ClearButtonVisibility="WhileEditing"
                           TextColor="#212121"/>
                </VerticalStackLayout>
            </Border>

            <!-- Due Date -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding [DueDate], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <DatePicker Date="{Binding DueDate}" BackgroundColor="Transparent" TextColor="#212121"/>
                </VerticalStackLayout>
            </Border>

            <!-- Category -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding [Category], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                        
                        <Border Grid.Row="0" Grid.Column="0" Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8" HeightRequest="70">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory}" Value="0">
                                    <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                    <Setter Property="Stroke" Value="#2196F3" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory, Converter={StaticResource InvertedBoolConverter}}" Value="False">
                                    <Setter Property="BackgroundColor" Value="White" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="{x:Static entities:CategoryType.Electricity}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="⚡" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="{Binding [Electricity], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="11" TextColor="Gray" HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding SelectedCategory}" Value="0">
                                            <Setter Property="TextColor" Value="#2196F3" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Row="0" Grid.Column="1" Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8" HeightRequest="70">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory}" Value="1">
                                    <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                    <Setter Property="Stroke" Value="#2196F3" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory, Converter={StaticResource InvertedBoolConverter}}" Value="False">
                                    <Setter Property="BackgroundColor" Value="White" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="{x:Static entities:CategoryType.Water}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="💧" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="{Binding [Water], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="11" TextColor="Gray" HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding SelectedCategory}" Value="1">
                                            <Setter Property="TextColor" Value="#2196F3" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Row="0" Grid.Column="2" Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8" HeightRequest="70">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory}" Value="2">
                                    <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                    <Setter Property="Stroke" Value="#2196F3" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory, Converter={StaticResource InvertedBoolConverter}}" Value="False">
                                    <Setter Property="BackgroundColor" Value="White" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="{x:Static entities:CategoryType.Internet}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="🌐" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="{Binding [Internet], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="11" TextColor="Gray" HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding SelectedCategory}" Value="2">
                                            <Setter Property="TextColor" Value="#2196F3" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Row="1" Grid.Column="0" Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8" HeightRequest="70">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory}" Value="3">
                                    <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                    <Setter Property="Stroke" Value="#2196F3" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory, Converter={StaticResource InvertedBoolConverter}}" Value="False">
                                    <Setter Property="BackgroundColor" Value="White" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="{x:Static entities:CategoryType.Rent}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="🏠" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="Rent" FontSize="11" TextColor="Gray" HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding SelectedCategory}" Value="3">
                                            <Setter Property="TextColor" Value="#2196F3" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Row="1" Grid.Column="1" Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8" HeightRequest="70">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory}" Value="4">
                                    <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                    <Setter Property="Stroke" Value="#2196F3" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory, Converter={StaticResource InvertedBoolConverter}}" Value="False">
                                    <Setter Property="BackgroundColor" Value="White" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="{x:Static entities:CategoryType.Subscription}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="📺" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="Subscription" FontSize="11" TextColor="Gray" HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding SelectedCategory}" Value="4">
                                            <Setter Property="TextColor" Value="#2196F3" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Row="1" Grid.Column="2" Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8" HeightRequest="70">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory}" Value="5">
                                    <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                    <Setter Property="Stroke" Value="#2196F3" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedCategory, Converter={StaticResource InvertedBoolConverter}}" Value="False">
                                    <Setter Property="BackgroundColor" Value="White" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="{x:Static entities:CategoryType.Other}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="📄" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="Other" FontSize="11" TextColor="Gray" HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding SelectedCategory}" Value="5">
                                            <Setter Property="TextColor" Value="#2196F3" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Payment Method -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding [PaymentMethod], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <Picker SelectedItem="{Binding PaymentMethod}" Title="Select method..." BackgroundColor="Transparent" TextColor="#212121">
                        <Picker.Items>
                            <x:String>Cash</x:String>
                            <x:String>Mobile Money</x:String>
                            <x:String>Bank Transfer</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <!-- Notes -->
            <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 12" 
                    BackgroundColor="White" Padding="16,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding [Notes], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#757575"/>
                    <Editor Text="{Binding Notes}" Placeholder="Add notes..." HeightRequest="80" 
                            BackgroundColor="Transparent" AutoSize="TextChanges" TextColor="#212121"/>
                </VerticalStackLayout>
            </Border>

            <!-- Save Button -->
            <Button Text="{Binding [SaveInvoice], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding SaveInvoiceCommand}"
                    BackgroundColor="#3498DB" TextColor="White" 
                    CornerRadius="8" HeightRequest="50" FontAttributes="Bold"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
