<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BillWise.ViewModels"
             xmlns:strings="clr-namespace:BillWise.Resources.Strings"
             x:Class="BillWise.Views.AddInvoicePage"
             x:DataType="vm:AddInvoiceViewModel"
             BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Custom Header -->
        <Border Grid.Row="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}" StrokeThickness="0" Padding="0" Margin="0">
            <VerticalStackLayout>
                <Grid ColumnDefinitions="Auto, *" Padding="20,16,20,16">
                    <Label Text="←" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#001F3F, Dark=#F9FAFB}" VerticalOptions="Center" Margin="0,0,16,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Grid.Column="1" Text="{Binding [NewInvoice], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#001F3F, Dark=#F9FAFB}" VerticalOptions="Center"/>
                </Grid>
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"/>
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="20,16,20,30">

                <!-- Top Action Buttons -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12" Margin="0,0,0,4">

                    <!-- Scan Button -->
                    <Border Grid.Column="0" Stroke="#3498DB" StrokeThickness="1"
                            StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                            Padding="0,16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ScanCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="📷" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Scan], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                FontSize="12" TextColor="#3498DB" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Voice Button -->
                    <Border Grid.Column="1" StrokeThickness="1"
                            Stroke="{Binding VoiceButtonColor}"
                            StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                            Padding="0,16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VoiceCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="🎤" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Voice], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                FontSize="12" TextColor="{Binding VoiceButtonColor}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Location Button -->
                    <Border Grid.Column="2" Stroke="#2ECC71" StrokeThickness="1"
                            StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                            Padding="0,16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LocationCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="📍" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding [Location], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                FontSize="12" TextColor="#2ECC71" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- Bill Name -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding [InvoiceName], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#9CA3AF}"/>
                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#374151}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                            Padding="14,0" HeightRequest="52">
                        <Entry Text="{Binding InvoiceName, Mode=TwoWay}"
                               Placeholder="e.g., Electricity Bill"
                               PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"
                               TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                               VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Amount -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding [Amount], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#9CA3AF}"/>
                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#374151}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                            Padding="14,0" HeightRequest="52">
                        <Entry Text="{Binding AmountText, Mode=TwoWay}"
                               Placeholder="£0.00" Keyboard="Numeric"
                               PlaceholderColor="#9CA3AF" BackgroundColor="Transparent"
                               TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                               VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Due Date -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding [DueDate], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#9CA3AF}"/>
                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#374151}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                            Padding="14,0" HeightRequest="52">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDateFieldTapped"/>
                        </Border.GestureRecognizers>
                        <Grid>
                            <DatePicker x:Name="DatePickerControl" Date="{Binding DueDate}" TextColor="Transparent" BackgroundColor="Transparent" DateSelected="OnDateSelected"/>
                            <Label Text="{Binding DueDateText}" TextColor="{Binding DueDateColor}" VerticalOptions="Center" InputTransparent="True"/>
                            <Label Text="📅" HorizontalOptions="End" VerticalOptions="Center" FontSize="16" InputTransparent="True" Margin="0,0,4,0"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Category -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding [Category], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#9CA3AF}"/>
                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#374151}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                            Padding="14,0" HeightRequest="52">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenCategoryPickerCommand}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <Label Grid.Column="0" Text="{Binding SelectedCategoryLabel}"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                                   VerticalOptions="Center" FontSize="14"/>
                            <Label Grid.Column="1" Text="›" FontSize="22" TextColor="#9CA3AF" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Payment Method -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding [PaymentMethod], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#9CA3AF}"/>
                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#374151}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                            Padding="14,0" HeightRequest="52">
                        <Picker ItemsSource="{Binding PaymentMethodOptions}"
                                SelectedItem="{Binding PaymentMethod, Mode=TwoWay}"
                                Title="{Binding [SelectMethod], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                TitleColor="#9CA3AF" BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                                VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Notes -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding [Notes], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#9CA3AF}"/>
                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#374151}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
                            Padding="14,10" MinimumHeightRequest="90">
                        <Editor Text="{Binding Notes}"
                                Placeholder="{Binding [AddNotes], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                PlaceholderColor="#9CA3AF"
                                BackgroundColor="Transparent"
                                AutoSize="TextChanges"
                                TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Save Button -->
                <Button Text="{Binding [SaveInvoice], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                        Command="{Binding SaveInvoiceCommand}"
                        BackgroundColor="#3498DB" TextColor="White"
                        CornerRadius="12" HeightRequest="54" FontAttributes="Bold"
                        FontSize="16" Margin="0,8,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
